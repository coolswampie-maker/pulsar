# Скопируйте в .env и заполните. .env НЕ коммитить.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
# Хосты, с которых доступен бэкенд (через запятую)
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres в РФ (152-ФЗ). Пример для Timeweb/Yandex Cloud/Selectel:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# Если не задано — используется локальный SQLite (только для разработки).
DATABASE_URL=

# Откуда фронт может обращаться к API (домен демо и локалка)
CORS_ALLOWED_ORIGINS=http://localhost:4177,https://pulsar.zimermans.ru
